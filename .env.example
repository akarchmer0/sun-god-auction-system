# Keep this file as a template. Put your real key in a separate .env file.
# Fast, expressive auctioneer speech. Create a key at play.cartesia.ai/keys.
CARTESIA_API_KEY=your_cartesia_api_key_here

# Optional: Lucy is the default British auctioneer voice. Paste another Cartesia voice ID here to change it.
CARTESIA_VOICE_ID=2f251ac3-89a9-4a77-a452-704b474ccd01

# Optional: pin a different compatible Sonic model.
CARTESIA_MODEL=sonic-3.5

# Optional: use an ElevenLabs auctioneer voice over one persistent multi-context stream.
# Create a key in ElevenLabs, save/share an Auctioneer voice, and paste its voice ID below.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# Optional: Flash v2.5 is the low-latency model recommended for realtime WebSocket speech.
ELEVENLABS_MODEL=eleven_flash_v2_5

# Optional: adds live, context-aware fantasy-football roast writing. The key remains on this Mac.
# Without it, Lucy uses the built-in contextual roast rotation.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use another text model for roast writing.
OPENAI_ROAST_MODEL=gpt-5.6-luna

# Optional: use another low-latency text model for three-line live patter direction.
OPENAI_PATTER_MODEL=gpt-5.6-luna

# Optional: use another low-latency text model for per-nomination auto-draft intent decisions.
OPENAI_AUTODRAFT_MODEL=gpt-5.6-luna
