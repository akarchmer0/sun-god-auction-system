# Keep this file as a template. Put your real key in a separate .env file.
OPENAI_API_KEY=your_openai_api_key_here

# Fast, expressive auctioneer speech. Create a key at play.cartesia.ai/keys.
CARTESIA_API_KEY=your_cartesia_api_key_here

# Optional: Lucy is the default British auctioneer voice. Paste another Cartesia voice ID here to change it.
CARTESIA_VOICE_ID=2f251ac3-89a9-4a77-a452-704b474ccd01

# Optional: pin a different compatible Sonic model.
CARTESIA_MODEL=sonic-3.5

# Optional: use a different compatible text model.
GAVEL_INTENT_MODEL=gpt-5-mini

# The live microphone transcription model.
GAVEL_TRANSCRIPTION_MODEL=gpt-realtime-whisper
